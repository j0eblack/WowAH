HTTP_PORT=3000
HTTPS_PORT=3443
SESSION_SECRET=change-this-to-a-random-string

# Production SSL — leave blank to use an auto-generated self-signed cert (dev only)
# SSL_CERT=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_KEY=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# Blizzard API credentials (OAuth client credentials).
# Create a client at https://develop.battle.net/ — use "Blizzard API" product.
BLIZZARD_CLIENT_ID=your_client_id_here
BLIZZARD_CLIENT_SECRET=your_client_secret_here
DEFAULT_REGION=eu

# Optional: add SMTP credentials to send real verification emails.
# Without these, the verification link is printed to the server console instead.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=yourpassword
# SMTP_FROM=noreply@wowah.local
